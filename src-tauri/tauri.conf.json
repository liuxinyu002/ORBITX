{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "OrbitX",
  "version": "0.1.0",
  "identifier": "com.orbitx.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "OrbitX",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 700,
        "decorations": true,
        "transparent": false,
        "center": true,
        "create": false
      },
      {
        "label": "overlay",
        "title": "OrbitX Overlay",
        "url": "/#/overlay",
        "visible": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "center": false,
        "width": 480,
        "height": 48,
        "resizable": false,
        "shadow": false,
        "create": false
      },
      {
        "label": "toast",
        "title": "OrbitX Toast",
        "url": "/#/toast",
        "visible": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "center": false,
        "width": 480,
        "height": 48,
        "resizable": false,
        "shadow": false,
        "create": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "languages": ["SimpChinese"],
        "installMode": "currentUser"
      }
    }
  }
}
