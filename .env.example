# OrbitX 运行时可调参数
# 复制此文件为 .env 并修改配置值

# 日志级别 (RUST_LOG): error | warn | info | debug
# 也可按模块细粒度控制，如 orbitx_lib=debug,info
RUST_LOG=info

# 运行环境: development | production
NODE_ENV=development

# 剪贴板降级通道超时时间（毫秒），默认 80
# CLIPBOARD_TIMEOUT_MS=80

# 剪贴板降级通道轮询间隔（毫秒），默认 5
# CLIPBOARD_POLL_INTERVAL_MS=5

# AI 提取管线超时时间（毫秒），超时后 Fail Fast 不重试，默认 30000
# EXTRACTION_TIMEOUT_MS=30000
