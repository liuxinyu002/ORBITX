# OrbitX 运行时可调参数
# 复制此文件为 .env 并修改配置值

# 日志级别 (RUST_LOG): error | warn | info | debug
# 也可按模块细粒度控制，如 orbitx_lib=debug,info
RUST_LOG=info

# 运行环境: development | production
NODE_ENV=development

# 剪贴板降级通道超时时间（毫秒），默认 200
# 200ms 覆盖多数应用的 Ctrl+C 响应时间（含 Electron 等重应用的 IPC 往返）
# 若目标应用响应较慢可继续调高
# CLIPBOARD_TIMEOUT_MS=200

# 剪贴板降级通道轮询间隔（毫秒），默认 5
# CLIPBOARD_POLL_INTERVAL_MS=5

# AI 提取管线超时时间（毫秒），超时后 Fail Fast 不重试，默认 30000
# VITE_EXTRACTION_TIMEOUT_MS=30000

# Toast 消息自动消失时间（毫秒），默认 2500
# TOAST_DURATION_MS=2500
